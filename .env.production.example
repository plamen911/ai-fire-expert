APP_NAME="Forensic Fire Expert"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=bg
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (matches docker-compose.prod.yml postgres service)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel_rag
DB_USERNAME=laravel_rag
DB_PASSWORD=        # REQUIRED: Set a strong password (must match DOCKER_DB_PASSWORD)

# Docker Compose postgres env vars (must match DB_ values above)
DOCKER_DB_DATABASE=laravel_rag
DOCKER_DB_USERNAME=laravel_rag
DOCKER_DB_PASSWORD= # REQUIRED: Same as DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI API Keys (at least one is required for RAG to work)
GROQ_API_KEY=      # Free tier available at console.groq.com
OPENAI_API_KEY=    # For embeddings: platform.openai.com
COHERE_API_KEY=    # For reranking: dashboard.cohere.com

VITE_APP_NAME="${APP_NAME}"
